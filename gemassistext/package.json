{
  "name": "gemini-copilot",
  "displayName": "Gemini Copilot",
  "description": "A VS Code extension to provide Copilot-like functionality using the Gemini API.",
  "version": "0.0.1",
  "publisher": "vscode-developer",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onCommand:gemini-copilot.setApiKey",
    "onChatParticipant:tutor.chatParticipant"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gemini-copilot.setApiKey",
        "title": "Gemini Copilot: Set API Key",
        "category": "Gemini Copilot"
      },
      {
        "command": "gemini-copilot.generateInNewFile",
        "title": "Gemini Copilot: Generate Code in New File",
        "category": "Gemini Copilot"
      }
    ],
    "keybindings": [
      {
        "command": "gemini-copilot.generateInNewFile",
        "key": "ctrl+i",
        "mac": "cmd+i"
      }
    ],
    "chatParticipants": [
      {
        "id": "gemini.chatParticipant",
        "name": "CodeTutor",
        "description": "tutor",
        "isSticky": true,
        "commands": [
          {
            "name": "explain",
            "description": "Explain the selected code"
          },
          {
            "name": "fix",
            "description": "Suggest a fix for the selected code"
          }
        ]
      }
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.1.0"
  }
}
