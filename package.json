{
  "name": "gemini-copilot",
  "displayName": "Gemini Copilot",
  "description": "A VS Code extension to provide Copilot-like functionality using the Gemini API.",
  "version": "0.0.1",
  "publisher": "vscode-developer",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onCommand:gemini-copilot.setApiKey",
    "onChatParticipant:gemini.chatParticipant"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gemini-copilot.setApiKey",
        "title": "Gemini Copilot: Set API Key",
        "category": "Gemini Copilot"
      }
    ],
    "chatParticipants": [
      {
        "id": "gemini.chatParticipant",
        "name": "Gemini"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "eslint": "^8.57.0",
    "globals": "^16.3.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.41.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.1.0"
  }
}
